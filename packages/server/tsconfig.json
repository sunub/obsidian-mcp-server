{
        "extends": "../../tsconfig.base.json",
        "compilerOptions": {
                "outDir": "./build",
                "rootDir": "./src",
                "baseUrl": ".",
                "declaration": true,
                "emitDeclarationOnly": true,
                "declarationMap": true,
                "paths": {
                        "@/*": ["./src/*"],
                        "@sunub/core": ["../core/src/index.ts"],
                        "@core/*": ["../core/src/*"]
                }
        },
        "references": [{ "path": "../core" }],
        "include": ["src/**/*"]
}
