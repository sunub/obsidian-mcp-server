    "url": "git+https://github.com/sunub/obsidian-mcp-server.git",
    "directory": "packages/server"
  },
  "keywords": [
    "mcp",
    "obsidian",
    "rag",
    "ollama",
    "lancedb"
  ],
  "author": "sunub",
  "license": "MIT",
  "dependencies": {
    "@sunub/obsidian-mcp-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.1",
    "@lancedb/lancedb": "^0.10.0",
    "ollama": "^0.5.8",
    "zod": "^3.23.8",
    "gray-matter": "^4.0.3",
    "glob": "^11.0.0",
    "mime-types": "^2.1.35",
    "canvas": "^2.11.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/mime-types": "^2.1.4",
    "vitest": "^2.0.1"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
