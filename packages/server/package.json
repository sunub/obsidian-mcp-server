{
  "name": "@sunub/obsidian-mcp-server",
  "version": "0.3.15",
  "description": "Obsidian Local RAG MCP Server",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "bin": {
    "obsidian-mcp-server": "./build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --target node --outdir ./build --sourcemap && tsc --emitDeclarationOnly",
    "start": "bun run ./src/index.ts",
    "test": "vitest run",
    "prepublishOnly": "shx cp ../../README.md . && shx cp ../../LICENSE ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sunub/obsidian-mcp-server.git",
    "directory": "packages/server"
  },
  "keywords": [
    "mcp",
    "obsidian",
    "rag",
    "ollama",
    "lancedb"
  ],
  "author": "sunub",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "@lancedb/lancedb": "^0.10.0",
    "ollama": "^0.5.8",
    "zod": "^3.23.8",
    "gray-matter": "^4.0.3",
    "glob": "^11.0.0",
    "mime-types": "^2.1.35",
    "canvas": "^2.11.2",
    "chalk": "^5.3.0",
    "@huggingface/transformers": "^3.3.3",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "apache-arrow": "^19.0.1",
    "@langchain/textsplitters": "^0.1.0",
    "js-tiktoken": "^1.0.19",
    "ora": "^9.2.1",
    "inquirer": "^12.4.1"
  },
  "devDependencies": {
    "@sunub/obsidian-mcp-core": "workspace:*",
    "@types/node": "^20.14.10",
    "@types/mime-types": "^2.1.4",
    "@types/inquirer": "^9.0.7",
    "vitest": "^2.0.1",
    "shx": "^0.4.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
