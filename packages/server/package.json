{
  "name": "@sunub/obsidian-mcp-server",
  "version": "0.3.15",
  "description": "Obsidian Local RAG MCP Server",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "bin": {
    "obsidian-mcp-server": "./build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --target node --outdir ./build --sourcemap",
    "start": "bun run ./src/index.ts",
    "test": "vitest run"
  },
  "repository": {
