{
	"name": "@sunub/obsidian-mcp-server",
	"version": "0.3.9",
	"description": "A server for the Obsidian Model Context Protocol.",
	"type": "module",
	"bin": {
		"obsidian-mcp-server": "build/index.js",
		"obsidian-mcp-setup": "build/setup.js"
	},
	"exports": {
		".": "./build/index.js"
	},
	"files": [
		"build"
	],
	"scripts": {
		"build": "tsc && tsc-alias && shx chmod +x build/index.js",
		"start": "node build/index.js"
	},
	"dependencies": {
		"@sunub/obsidian-mcp-core": "workspace:*",
		"@huggingface/transformers": "^4.2.0",
		"@lancedb/lancedb": "^0.27.2",
		"@langchain/core": "^1.1.39",
		"@langchain/textsplitters": "^1.0.1",
		"@modelcontextprotocol/sdk": "^1.17.5",
		"apache-arrow": "^18.1.0",
		"chokidar": "^5.0.0",
		"commander": "^14.0.2",
		"comment-json": "^5.0.0",
		"dotenv": "^17.4.2",
		"gray-matter": "^4.0.3",
		"js-tiktoken": "^1.0.21",
		"ollama": "^0.6.3",
		"ora": "^9.3.0",
		"chalk": "^5.6.2",
		"inquirer": "^13.4.2",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"tsc-alias": "^1.8.16",
		"typescript": "^5.9.2",
		"shx": "^0.4.0"
	}
}
