{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "./build",
		"rootDir": "./src",
		"baseUrl": ".",
		"paths": {
			"@cli/*": ["./src/*"],
			"@sunub/obsidian-mcp-core": ["../core/src/index.ts"],
			"@sunub/obsidian-mcp-server": ["../server/src/index.ts"],
			"@/*": ["../server/src/*"]
		}
	},
	"references": [
		{
			"path": "../core"
		},
		{
			"path": "../server"
		}
	],
	"include": ["src/**/*"]
}
