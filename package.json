{
	"name": "obsidian-mcp-monorepo",
	"version": "0.3.12",
	"author": "sunub",
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@types/node": "^24.3.1",
		"shx": "^0.4.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.2",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.2.4"
	},
	"description": "Monorepo for Obsidian MCP Server and CLI Agent",
	"license": "ISC",
	"private": true,
	"scripts": {
		"test": "vitest",
		"test:watch": "vitest --watch",
		"build": "bun run --filter \"*\" build",
		"format": "npx biome format --write .",
		"lint": "npx biome lint --write .",
		"check": "npx biome check --write .",
		"cli": "bun run --cwd packages/cli start",
		"server": "bun run --cwd packages/server start"
	},
	"type": "module",
	"workspaces": [
		"packages/*"
	]
}
